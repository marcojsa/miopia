# ============================================================
# miopia-app — variáveis de ambiente (copie para .env e preencha)
#
# Os valores abaixo são os DEFAULTS da instância local do
# `supabase start` (chaves demo públicas do CLI — não são segredo).
# Para staging/produção, troque pelos valores do projeto Supabase
# (região São Paulo) e NUNCA commite o .env real.
# ============================================================

# ------------------------------------------------------------
# Supabase local (scripts/smoke-rls.mjs e ferramentas de dev)
# `supabase start` imprime esses três valores ao subir.
# ------------------------------------------------------------
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
# Service role: SÓ em scripts de dev e Edge Functions. JAMAIS no app/painel.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# ------------------------------------------------------------
# Edge Functions (supabase/functions/*)
# SUPABASE_URL / SUPABASE_ANON_KEY / SUPABASE_SERVICE_ROLE_KEY são
# injetadas automaticamente pelo runtime (local e na nuvem).
# As extras abaixo: local em supabase/functions/.env, remoto via
# `supabase secrets set`.
# ------------------------------------------------------------
# Deep link de aceite do convite (placeholder até o app Expo ter o
# scheme final; precisa constar em additional_redirect_urls do config.toml)
INVITE_REDIRECT_TO=miopia://convite

# ------------------------------------------------------------
# apps/mobile — app do responsável (Expo / React Native)
# Prefixo EXPO_PUBLIC_ = embutido no bundle (só URL + anon key!)
# ------------------------------------------------------------
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# ------------------------------------------------------------
# apps/panel — painel da clínica (Vite / React)
# Prefixo VITE_ = embutido no bundle (só URL + anon key!)
# ------------------------------------------------------------
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# ------------------------------------------------------------
# SMTP custom (Resend) — OBRIGATÓRIO antes do piloto: o SMTP default
# do Supabase manda ~3 e-mails/h e mata o fluxo invite-only.
# Local: e-mails caem no Inbucket (http://127.0.0.1:54324), sem SMTP.
# ------------------------------------------------------------
# RESEND_API_KEY=

# Opcional: assistente de IA do Supabase Studio local
# OPENAI_API_KEY=
